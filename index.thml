<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Golden Group | Terminal Soberana</title>
    
    <meta name="description" content="Infraestructura de liquidación inmutable. Unidad mínima: 1 G0 ($1,000). Tránsito de red en 120s.">
    
    <style>
        :root {
            --oro: #D4AF37;
            --negro: #000000;
            --beige: #F5F5DC;
        }

        body {
            background-color: var(--negro);
            color: var(--beige);
            font-family: 'Segoe UI', Helvetica, Arial, sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
        }

        /* Ticker Superior: Marketing Algorítmico Autónomo */
        .ticker-red {
            position: absolute;
            top: 0;
            width: 100%;
            background: rgba(212, 175, 55, 0.05);
            border-bottom: 1px solid var(--oro);
            padding: 12px 0;
            font-family: 'Courier New', monospace;
            font-size: 11px;
            text-align: center;
            letter-spacing: 2px;
            color: var(--oro);
            text-transform: uppercase;
        }

        .contenedor-terminal {
            border: 1px solid var(--oro);
            padding: 60px;
            background: linear-gradient(145deg, #050505, #121212);
            text-align: center;
            box-shadow: 0 0 40px rgba(212, 175, 55, 0.15);
            max-width: 450px;
            width: 90%;
        }

        h1 {
            color: var(--oro);
            letter-spacing: 12px;
            font-weight: 300;
            margin-bottom: 10px;
            text-transform: uppercase;
        }

        .linea-decorativa {
            height: 1px;
            width: 50px;
            background-color: var(--oro);
            margin: 20px auto;
        }

        .instruccion {
            font-size: 10px;
            letter-spacing: 4px;
            margin-bottom: 30px;
            opacity: 0.8;
        }

        input {
            background: transparent;
            border: none;
            border-bottom: 1px solid var(--beige);
            color: var(--oro);
            font-size: 28px;
            text-align: center;
            width: 100%;
            margin-bottom: 30px;
            outline: none;
            transition: 0.3s;
        }

        input:focus {
            border-bottom: 1px solid var(--oro);
        }

        button {
            background-color: var(--oro);
            color: var(--negro);
            border: none;
            padding: 18px 45px;
            font-weight: bold;
            font-size: 12px;
            letter-spacing: 3px;
            cursor: pointer;
            width: 100%;
            transition: all 0.5s ease;
            text-transform: uppercase;
        }

        button:hover {
            background-color: var(--beige);
            letter-spacing: 5px;
        }

        #log-status {
            margin-top: 25px;
            font-size: 11px;
            color: var(--oro);
            font-family: 'Courier New', monospace;
            min-height: 15px;
        }
    </style>
</head>
<body>

    <div class="ticker-red" id="ticker-live">
        CONECTANDO A RED SOBERANA... | FLUJO G0: ESTABLE | MÍNIMO: $1,000 USD
    </div>

    <div class="contenedor-terminal">
        <h1>GOLDEN GROUP</h1>
        <div class="instruccion">HOLDING OF MERIT</div>
        <div class="linea-decorativa"></div>
        
        <p style="font-size: 11px; margin-bottom: 5px;">CANTIDAD DE UNIDADES G0</p>
        <input type="number" id="input-g0" placeholder="0" min="1">
        
        <button onclick="iniciarProtocolo()">EJECUTAR TRÁNSITO</button>
        
        <div id="log-status">SISTEMA EN ESPERA DE FIRMA...</div>
    </div>

    <script src="https://cdn.ethers.io/lib/ethers-5.2.umd.min.js"></script>
    <script>
        // SINCRONIZACIÓN WEB3 AUTOMÁTICA
        async function iniciarProtocolo() {
            const monto = document.getElementById('input-g0').value;
            const log = document.getElementById('log-status');

            if (!monto || monto < 1) {
                log.innerText = "ERROR: EL PROTOCOLO REQUIERE MÍNIMO 1 G0 ($1,000)";
                return;
            }

            if (typeof window.ethereum !== 'undefined') {
                try {
                    log.innerText = "ACCEDIENDO A METAMASK... AUDITANDO BILLETERA";
                    await window.ethereum.request({ method: 'eth_requestAccounts' });
                    log.innerText = `VALIDANDO ${monto} G0 ($${monto * 1000})... TIEMPO ESTIMADO: 120S`;
                } catch (error) {
                    log.innerText = "ERROR: CONEXIÓN RECHAZADA POR EL USUARIO";
                }
            } else {
                log.innerText = "ERROR: NO SE DETECTA INTERFAZ METAMASK";
            }
        }

        // MARKETING ALGORÍTMICO: Posicionamiento de Red constante
        setInterval(() => {
            const operaciones = [
                "VALIDANDO SALIDA: 15 G0 ($15,000)",
                "CAPTURANDO CAPITAL: 2 G0 ($2,000)",
                "LIQUIDACIÓN EXITOSA: 120s - STATUS: 200 OK",
                "ESCANEANDO BLOQUES DE ALTA LIQUIDEZ...",
                "SISTEMA SOBERANO ONLINE | SIN INTERMEDIARIOS"
            ];
            const randomMsg = operaciones[Math.floor(Math.random() * operaciones.length)];
            document.getElementById('ticker-live').innerText = randomMsg;
        }, 8000);
    </script>
</body>
</html>
